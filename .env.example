# =============================================================================
# Openclaw Railway Template - Environment Variables
# =============================================================================
# Copy this file to .env for local development
# For Railway deployment, set these in the Railway dashboard Variables section
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED VARIABLES (for zero-touch auto-onboard)
# -----------------------------------------------------------------------------

# AI provider to use. Determines how the agent connects to the LLM backend.
# Valid values: anthropic, openai, openrouter, gemini, google, ai-gateway,
#               moonshot, kimi-code, zai, minimax, synthetic, opencode-zen
AI_PROVIDER=anthropic

# API key for the chosen AI provider.
# Example for Anthropic: sk-ant-...
# Example for OpenAI: sk-...
AI_API_KEY=

# Override the default model for this agent.
# If unset, uses the provider default.
# Examples: together/Qwen/Qwen3.5-9B, together/Qwen/Qwen3.5-27B, anthropic/claude-sonnet-4-6
AI_MODEL=

# Telegram bot token (from @BotFather).
# The bot will be auto-configured and a message sent on deploy.
TELEGRAM_BOT_TOKEN=

# Telegram username or chat ID for USER.md (so BOOTSTRAP.md and the agent can message you).
# Accepts @username (e.g. @johndoe) or numeric chat ID (e.g. 123456789).
# The user must have messaged the bot at least once for @username resolution to work.
# If not set, the wrapper uses the most recent getUpdates chat (send /start before first deploy so it's seen).
TELEGRAM_USERNAME=

# Senpi auth token for the MCP integration.
# Injected into the mcporter config so the agent can use Senpi tools.
SENPI_AUTH_TOKEN=

# Set to "false" to disable the @senpi-ai/runtime plugin. When enabled, bootstrap runs
# "openclaw plugins install @senpi-ai/runtime" when config exists and the plugin is not yet installed.
# SENPI_TRADING_RUNTIME_ENABLED=

# Directory where openclaw stores configuration and state
# MUST point to /data on Railway (volume mount) for persistence
OPENCLAW_STATE_DIR=/data/.openclaw

# Directory where openclaw stores workspace files
# MUST point to /data on Railway (volume mount) for persistence
OPENCLAW_WORKSPACE_DIR=/data/workspace

# -----------------------------------------------------------------------------
# OPTIONAL VARIABLES
# -----------------------------------------------------------------------------

# Password for /setup wizard and for gateway/Control UI (/, /openclaw).
# Optional: if unset, /setup and gateway routes are disabled (return 500) and a
# prominent startup warning is logged — the deployment is not publicly open.
# Senpi trading runtime plugin state directory (strategies, DSL state)
SENPI_STATE_DIR=/data/.openclaw/senpi-state

# Recommended for production: set this to enable the setup wizard and Control UI.
# For Railway: Use ${{ secret() }} to generate a random secure password.
SETUP_PASSWORD=

# Authentication token for the openclaw gateway and Control UI
# For Railway: Use ${{ secret() }} to generate a stable secret
# For local: Generate with: openssl rand -hex 32
# If not set, the wrapper will generate one automatically
OPENCLAW_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL VARIABLES (Usually don't need to change)
# -----------------------------------------------------------------------------

# Port the wrapper server listens on
# Railway sets this automatically, usually to 8080
PORT=8080

# Internal port where the gateway listens (proxied by the wrapper)
# Default: 18789
INTERNAL_GATEWAY_PORT=18789

# Internal host for the gateway
# Default: 127.0.0.1
INTERNAL_GATEWAY_HOST=127.0.0.1

# Path to the openclaw configuration file
# Default: ${OPENCLAW_STATE_DIR}/openclaw.json
# Leave empty to use the default
OPENCLAW_CONFIG_PATH=

# Path to the openclaw CLI entry point
# Default: /openclaw/dist/entry.js
# Leave empty unless using a custom build
OPENCLAW_ENTRY=/openclaw/dist/entry.js

# Node.js executable to use
# Default: node
# Leave empty unless you need a specific node binary
OPENCLAW_NODE=node

# Enable debug logging and /setup/api/debug endpoint (internal structure, paths, versions).
# Set to "true" for detailed token logs and to enable GET /setup/api/debug.
# Default: not set (debug disabled; debug endpoint returns 404 in production).
OPENCLAW_TEMPLATE_DEBUG=

# -----------------------------------------------------------------------------
# RAILWAY-SPECIFIC VARIABLES (Set automatically by Railway)
# -----------------------------------------------------------------------------

# Git commit SHA - automatically set by Railway during deployment
# Do not set manually
# RAILWAY_GIT_COMMIT_SHA=

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. For Railway deployment, you MUST have a Volume mounted at /data
# 2. Without the volume, configuration will be lost on every redeploy
# 3. Zero-touch deploy: set AI_PROVIDER, AI_API_KEY, TELEGRAM_BOT_TOKEN,
#    and SENPI_AUTH_TOKEN — everything auto-configures on first deploy
# 4. Set SETUP_PASSWORD to enable /setup and Control UI; if unset, those
#    routes are disabled and a startup warning is logged
# =============================================================================
